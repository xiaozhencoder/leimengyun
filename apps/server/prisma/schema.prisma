generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户体系
// ============================================

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

model User {
  id           String     @id @default(uuid())
  phone        String     @unique
  passwordHash String?    @map("password_hash")
  role         UserRole
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
  sentMessages   Message[]       @relation("SentMessages")

  doctorBindsAsPatient DoctorPatientBind[] @relation("PatientBinds")
  doctorBindsAsDoctor  DoctorPatientBind[] @relation("DoctorBinds")

  conversationsAsPatient Conversation[] @relation("PatientConversations")
  conversationsAsDoctor  Conversation[] @relation("DoctorConversations")

  // 社区关系
  posts         Post[]
  comments      Comment[]
  postLikes     PostLike[]
  postCollects  PostCollect[]
  commentLikes  CommentLike[]
  followers     UserFollow[]   @relation("UserFollowers")
  followings    UserFollow[]   @relation("UserFollowings")
  checkIns      CheckIn[]

  // 问卷关系
  createdTemplates    QuestionnaireTemplate[]    @relation("TemplateCreator")
  sentAssignments     QuestionnaireAssignment[]  @relation("AssignmentDoctor")
  receivedAssignments QuestionnaireAssignment[]  @relation("AssignmentPatient")

  @@map("users")
}

enum DiabetesType {
  TYPE_1
  TYPE_2
  GESTATIONAL
  OTHER
}

enum TreatmentPlan {
  CSII
  MDI
  ORAL
  LIFESTYLE
}

model PatientProfile {
  id            String        @id @default(uuid())
  userId        String        @unique @map("user_id")
  nickname      String
  gender        String
  birthDate     DateTime      @map("birth_date")
  diabetesType  DiabetesType  @map("diabetes_type")
  diagnosisDate DateTime?     @map("diagnosis_date")
  treatmentPlan TreatmentPlan @map("treatment_plan")
  height        Float?
  weight        Float?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id])
  bloodSugarRecords BloodSugarRecord[]
  dietRecords       DietRecord[]
  medicationRecords MedicationRecord[]

  @@map("patient_profiles")
}

enum DoctorTitle {
  CHIEF
  ASSOCIATE_CHIEF
  ATTENDING
  RESIDENT
}

enum VerifyStatus {
  PENDING
  APPROVED
  REJECTED
}

model DoctorProfile {
  id           String       @id @default(uuid())
  userId       String       @unique @map("user_id")
  realName     String       @map("real_name")
  hospital     String
  department   String
  title        DoctorTitle
  licenseNo    String       @map("license_no")
  specialties  String?
  bio          String?
  verifyStatus VerifyStatus @default(PENDING) @map("verify_status")
  rejectReason String?      @map("reject_reason")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("doctor_profiles")
}

enum BindStatus {
  PENDING
  ACCEPTED
  REJECTED
  REMOVED
}

model DoctorPatientBind {
  id        String     @id @default(uuid())
  doctorId  String     @map("doctor_id")
  patientId String     @map("patient_id")
  status    BindStatus @default(PENDING)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  doctor  User @relation("DoctorBinds", fields: [doctorId], references: [id])
  patient User @relation("PatientBinds", fields: [patientId], references: [id])

  @@unique([doctorId, patientId])
  @@map("doctor_patient_binds")
}

// ============================================
// 健康数据
// ============================================

enum MeasureTime {
  FASTING
  BEFORE_BREAKFAST
  AFTER_BREAKFAST
  BEFORE_LUNCH
  AFTER_LUNCH
  BEFORE_DINNER
  AFTER_DINNER
  BEFORE_SLEEP
  MIDNIGHT
  RANDOM
}

model BloodSugarRecord {
  id          String      @id @default(uuid())
  patientId   String      @map("patient_id")
  value       Float
  measureTime MeasureTime @map("measure_time")
  recordedAt  DateTime    @map("recorded_at")
  note        String?
  createdAt   DateTime    @default(now()) @map("created_at")

  patient PatientProfile @relation(fields: [patientId], references: [id])

  @@index([patientId, recordedAt])
  @@map("blood_sugar_records")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model DietRecord {
  id         String   @id @default(uuid())
  patientId  String   @map("patient_id")
  mealType   MealType @map("meal_type")
  foodItems  Json     @map("food_items")
  totalCarbs Float    @map("total_carbs")
  photoUrl   String?  @map("photo_url")
  recordedAt DateTime @map("recorded_at")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  patient PatientProfile @relation(fields: [patientId], references: [id])

  @@index([patientId, recordedAt])
  @@map("diet_records")
}

enum MedType {
  INSULIN
  ORAL
}

model MedicationRecord {
  id            String   @id @default(uuid())
  patientId     String   @map("patient_id")
  medType       MedType  @map("med_type")
  medName       String   @map("med_name")
  dosage        Float
  dosageUnit    String   @map("dosage_unit")
  injectionSite String?  @map("injection_site")
  recordedAt    DateTime @map("recorded_at")
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")

  patient PatientProfile @relation(fields: [patientId], references: [id])

  @@index([patientId, recordedAt])
  @@map("medication_records")
}

// ============================================
// 医患沟通 (IM)
// ============================================

enum ConversationStatus {
  ACTIVE
  CLOSED
}

model Conversation {
  id            String             @id @default(uuid())
  patientId     String             @map("patient_id")
  doctorId      String             @map("doctor_id")
  status        ConversationStatus @default(ACTIVE)
  lastMessageAt DateTime?          @map("last_message_at")
  createdAt     DateTime           @default(now()) @map("created_at")

  patient  User      @relation("PatientConversations", fields: [patientId], references: [id])
  doctor   User      @relation("DoctorConversations", fields: [doctorId], references: [id])
  messages Message[]

  @@unique([patientId, doctorId])
  @@map("conversations")
}

enum MessageContentType {
  TEXT
  IMAGE
  BLOOD_SUGAR_CARD
}

model Message {
  id             String             @id @default(uuid())
  conversationId String             @map("conversation_id")
  senderId       String             @map("sender_id")
  contentType    MessageContentType @default(TEXT) @map("content_type")
  content        String
  isRead         Boolean            @default(false) @map("is_read")
  createdAt      DateTime           @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================
// 糖友社区
// ============================================

enum PostType {
  NORMAL
  BLOOD_SUGAR_DIARY
  DOCTOR_ARTICLE
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  DELETED
}

model Post {
  id             String     @id @default(uuid())
  authorId       String     @map("author_id")
  contentType    PostType   @default(NORMAL) @map("content_type")
  title          String?
  content        String     @db.Text
  images         String[]   @default([])
  topicId        String?    @map("topic_id")
  bloodSugarData Json?      @map("blood_sugar_data")
  isAnonymous    Boolean    @default(false) @map("is_anonymous")
  likeCount      Int        @default(0) @map("like_count")
  commentCount   Int        @default(0) @map("comment_count")
  collectCount   Int        @default(0) @map("collect_count")
  status         PostStatus @default(PUBLISHED)
  isTop          Boolean    @default(false) @map("is_top")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  author   User       @relation(fields: [authorId], references: [id])
  topic    Topic?     @relation(fields: [topicId], references: [id])
  comments Comment[]
  likes    PostLike[]
  collects PostCollect[]

  @@index([authorId, createdAt])
  @@index([topicId, createdAt])
  @@index([status, createdAt])
  @@map("posts")
}

model Comment {
  id            String   @id @default(uuid())
  postId        String   @map("post_id")
  authorId      String   @map("author_id")
  content       String   @db.VarChar(500)
  parentId      String?  @map("parent_id")
  replyToUserId String?  @map("reply_to_user_id")
  likeCount     Int      @default(0) @map("like_count")
  createdAt     DateTime @default(now()) @map("created_at")

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[]     @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId, createdAt])
  @@map("comments")
}

model Topic {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  postCount   Int      @default(0) @map("post_count")
  isHot       Boolean  @default(false) @map("is_hot")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  posts Post[]

  @@map("topics")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostCollect {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_collects")
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@map("comment_likes")
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("UserFollowings", fields: [followerId], references: [id])
  following User @relation("UserFollowers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@map("user_follows")
}

model CheckIn {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      String
  bsInRange Boolean  @default(false) @map("bs_in_range")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("check_ins")
}

// ============================================
// 问卷管理
// ============================================

enum QuestionnaireCategory {
  BLOOD_SUGAR_MANAGEMENT
  DIET_MANAGEMENT
  EXERCISE_MANAGEMENT
  MEDICATION_ADHERENCE
  QUALITY_OF_LIFE
  HYPOGLYCEMIA_RISK
  FOOT_CARE
  MENTAL_HEALTH
  CUSTOM
}

enum TemplateStatus {
  ACTIVE
  ARCHIVED
}

enum AssignmentStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELLED
}

model QuestionnaireTemplate {
  id            String                 @id @default(uuid())
  title         String
  description   String?                @db.Text
  category      QuestionnaireCategory
  questions     Json
  totalScore    Int?                   @map("total_score")
  estimatedTime Int                    @default(5) @map("estimated_time")
  isSystem      Boolean                @default(true) @map("is_system")
  creatorId     String?                @map("creator_id")
  status        TemplateStatus         @default(ACTIVE)
  sortOrder     Int                    @default(0) @map("sort_order")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  creator     User?                    @relation("TemplateCreator", fields: [creatorId], references: [id])
  assignments QuestionnaireAssignment[]

  @@map("questionnaire_templates")
}

model QuestionnaireAssignment {
  id         String           @id @default(uuid())
  templateId String           @map("template_id")
  doctorId   String           @map("doctor_id")
  patientId  String           @map("patient_id")
  status     AssignmentStatus @default(PENDING)
  deadline   DateTime?
  message    String?          @db.VarChar(200)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  template QuestionnaireTemplate  @relation(fields: [templateId], references: [id])
  doctor   User                   @relation("AssignmentDoctor", fields: [doctorId], references: [id])
  patient  User                   @relation("AssignmentPatient", fields: [patientId], references: [id])
  response QuestionnaireResponse?

  @@index([doctorId, createdAt])
  @@index([patientId, status])
  @@map("questionnaire_assignments")
}

model QuestionnaireResponse {
  id              String   @id @default(uuid())
  assignmentId    String   @unique @map("assignment_id")
  answers         Json
  totalScore      Int?     @map("total_score")
  dimensionScores Json?    @map("dimension_scores")
  duration        Int?
  submittedAt     DateTime @default(now()) @map("submitted_at")
  doctorNote      String?  @db.Text @map("doctor_note")
  notedAt         DateTime? @map("noted_at")

  assignment QuestionnaireAssignment @relation(fields: [assignmentId], references: [id])

  @@map("questionnaire_responses")
}
